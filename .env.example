# Velo Performance Lab — environment variables
#
# Copy this file to `.env` and fill in the values:   cp .env.example .env
# `.env` is gitignored — never commit it or paste these values anywhere
# except here and the Netlify dashboard.
#
# IMPORTANT: the deployed site reads env vars from Netlify, not this file.
# After filling this out, either enter the same values in
#   Netlify → Site configuration → Environment variables
# or push them all up in one shot with the Netlify CLI:
#   npx netlify link          (first time only)
#   npx netlify env:import .env
# then trigger a redeploy. A local .env is only used by `netlify dev`
# when running the functions on your own machine.

# ---- Supabase (Project Settings → API) --------------------------------
# The project URL (ends in .supabase.co — not .com!)
SUPABASE_URL=https://napcsqiuowatqgonsnsz.supabase.co
# The `service_role` secret key (the long JWT labeled service_role, NOT anon)
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe (Developers → API keys / Webhooks) ------------------------
# Secret key: sk_test_… while testing, sk_live_… when you go live
STRIPE_SECRET_KEY=
# Signing secret of the webhook endpoint pointed at
# /.netlify/functions/stripe-webhook (starts with whsec_…)
STRIPE_WEBHOOK_SECRET=

# ---- Twilio (Console home page) ---------------------------------------
# Account SID (starts with AC…)
TWILIO_ACCOUNT_SID=
# Auth token (click to reveal on the console home page)
TWILIO_AUTH_TOKEN=
# The Twilio phone number you bought, E.164 format: +1XXXXXXXXXX
TWILIO_FROM_NUMBER=
# Who gets the booking/inquiry texts — comma-separate for multiple:
# +18135550199,+17275550123
SMS_NOTIFY_TO=
